generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  appointments  Appointment[]
  prescriptions Prescription[]
}

model Appointment {
  id            String    @id @default(cuid())
  patientId     String
  provider      String
  datetime      DateTime
  repeat        String
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Prescription {
  id              String   @id @default(cuid())
  patientId       String
  medication      String
  dosage          String
  quantity        Int
  refillOn        DateTime
  refillSchedule  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}